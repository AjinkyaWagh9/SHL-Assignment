# Copy to .env and fill in your keys. Never commit .env.
#
# Provider selection:
#   fallback (default) -> OpenAI primary, Groq, Gemini fallbacks
#   openai             -> OpenAI only (paid, reliable)
#   groq               -> Groq only (free TPD)
#   gemini             -> Gemini only (free RPM)
#   stub               -> Offline deterministic stub (used for wiring tests)
SHL_LLM_PROVIDER=fallback

# OpenAI (https://platform.openai.com/api-keys) — primary in fallback mode
# Default model is gpt-4o-mini; override with OPENAI_MODEL=gpt-4o for higher quality.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
